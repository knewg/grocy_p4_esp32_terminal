menu "GROCY TERMINAL"

    config GROCY_API_URL
        string "Grocy API Base URL"
        default "http://grocy.local"
        help
            Base URL of your Grocy instance, e.g. http://grocy.local or https://grocy.example.com.

    config GROCY_API_KEY
        string "Grocy API Key"
        default ""
        help
            Grocy API key. For production, leave blank and set via the on-device setup screen (stored in NVS).

    config GROCY_LOCATION_ID
        int "Grocy Location ID"
        default 1
        help
            Grocy location ID to filter displayed products. Overridden by NVS value set in setup screen.

    config GROCY_REFRESH_INTERVAL_SEC
        int "Product list refresh interval (seconds)"
        default 300
        range 10 3600
        help
            How often to re-fetch the product list from Grocy.

    config GROCY_OTA_MANIFEST_URL
        string "OTA Manifest URL"
        default ""
        help
            HTTPS URL to a JSON manifest file: {"version":"1.0.0","firmware_url":"https://..."}.
            Leave blank to disable OTA.

    config GROCY_OTA_CHECK_INTERVAL_SEC
        int "OTA check interval (seconds)"
        default 3600
        range 60 86400

    config GROCY_SCREEN_WAKE_CAMERA
        bool "Enable camera-based presence detection for screen wake"
        default n
        help
            When enabled, the onboard camera detects motion/presence and wakes the screen.
            Costs ~20-30 mA extra. Default: use MQTT trigger from Home Assistant.

    config GROCY_MQTT_BROKER_URL
        string "MQTT Broker URL"
        default "mqtt://homeassistant.local"
        help
            MQTT broker URL. Use mqtts:// for TLS (port 8883). Example: mqtt://192.168.1.10:1883

    config GROCY_MQTT_PORT
        int "MQTT Port (0 = use scheme default)"
        default 0
        range 0 65535

    config GROCY_MQTT_USERNAME
        string "MQTT Username"
        default ""

    config GROCY_MQTT_PASSWORD
        string "MQTT Password"
        default ""

    config GROCY_DEVICE_ID
        string "Device ID (overrides eFuse MAC)"
        default ""
        help
            Override the device ID used in MQTT topics. If blank, the 12-char hex eFuse MAC is used.

    config GROCY_MQTT_LOG_LEVEL
        int "MQTT log level (0=none 1=error 2=warn 3=info 4=debug)"
        default 2
        range 0 4

    config GROCY_WIFI_SSID
        string "WiFi SSID (initial flash default)"
        default ""
        help
            Default WiFi SSID. Overridden by NVS value set in setup screen.

    config GROCY_WIFI_PASSWORD
        string "WiFi Password (initial flash default)"
        default ""

    config GROCY_IMAGE_CACHE_SIZE
        int "Image cache size (number of images)"
        default 200
        range 10 500

endmenu
