# Linux host target — set via: idf.py --preview set-target linux

# These values satisfy CONFIG_ references in config.c when NVS has no stored value.
CONFIG_GROCY_WIFI_SSID=""
CONFIG_GROCY_WIFI_PASSWORD=""
CONFIG_GROCY_API_URL="http://grocy.local"
CONFIG_GROCY_API_KEY=""
CONFIG_GROCY_LOCATION_ID=1
CONFIG_GROCY_MQTT_BROKER_URL="mqtt://homeassistant.local"
CONFIG_GROCY_MQTT_USERNAME=""
CONFIG_GROCY_MQTT_PASSWORD=""
CONFIG_GROCY_MQTT_LOG_LEVEL=2
CONFIG_GROCY_DEVICE_ID=""
CONFIG_GROCY_IMAGE_CACHE_SIZE=200
CONFIG_GROCY_REFRESH_INTERVAL_SEC=300
CONFIG_GROCY_OTA_MANIFEST_URL=""
CONFIG_GROCY_OTA_CHECK_INTERVAL_SEC=3600
CONFIG_GROCY_SCREEN_WAKE_CAMERA=n
CONFIG_GROCY_MQTT_PORT=0
